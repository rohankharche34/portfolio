# Spotify Configuration (Backend - visitors see YOUR music)
# Get these from https://developer.spotify.com/dashboard

# Frontend build (public)
VITE_SPOTIFY_CLIENT_ID=your_client_id

# Backend (secret - add in Vercel Settings → Environment Variables)
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REFRESH_TOKEN=your_refresh_token

# Must match redirect URI in Spotify Dashboard
SPOTIFY_REDIRECT_URI=https://your-app.vercel.app/